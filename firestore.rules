rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper to check if the user is an authenticated admin
    function isAdmin() {
      return request.auth != null;
    }

    match /properties/{propertyId} {
      // Anyone can read active properties. Admin can read all properties.
      allow read: if resource == null || resource.data.status == 'active' || isAdmin();

      // Anyone can submit a new property listing request if it starts as 'pending'
      allow create: if request.resource.data.status == 'pending' || isAdmin();

      // Only the admin can update or delete properties
      allow update, delete: if isAdmin();
    }
  }
}
